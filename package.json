{
  "name": "vandijk.sh",
  "private": true,
  "description": "The vandijk.sh website.",
  "type": "module",
  "scripts": {
    "build": "bun run build.articles && bun run build.glyphs && qwik build && bun run build.prune",
    "build.articles": "bun run build.articles.metadata",
    "build.articles.metadata": "bun src/scripts/generate-articles-metadata.ts",
    "build.client": "vite build",
    "build.glyphs": "bun src/scripts/generate-glyph-frames.ts",
    "build.prune": "bun src/scripts/prune-generated-frame-sources.ts",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "dev": "bun run build.articles && bun run build.glyphs && vite --mode ssr",
    "dev.debug": "bun --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "oxfmt --write .",
    "fmt.check": "oxfmt --check .",
    "lint": "oxlint src adapters vite.config.ts",
    "preinstall": "bun scripts/setup.ts",
    "preview": "PREVIEW_BUILD=true bun run build.articles && bun run build.glyphs && qwik build preview && bun run build.prune && vite preview --open",
    "setup": "bun scripts/setup.ts",
    "start": "vite --open --mode ssr",
    "test": "bun test --pass-with-no-tests",
    "qwik": "qwik"
  },
  "dependencies": {
    "modern-normalize": "3.0.0",
    "typeit": "8.8.3"
  },
  "devDependencies": {
    "@builder.io/qwik": "1.20.0",
    "@builder.io/qwik-city": "1.20.0",
    "@danielvaijk/editor-config": "1.0.1",
    "@types/hast": "^3.0.4",
    "@types/node": "20.8.4",
    "hast-util-to-html": "^9.0.5",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "refractor": "^5.0.0",
    "sass": "1.89.2",
    "sharp": "0.34.2",
    "typescript": "^5.2.2",
    "vite": "5.4.19",
    "vite-tsconfig-paths": "4.2.1"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "sharp"
  ]
}
